[{
  "bookSourceName": "刺猬猫阅读",
  "bookSourceUrl": "https://www.ciweimao.com",
  "bookSourceType": 0,
  "bookSourceGroup": "网络小说",
  "customOrder": 1,
  "enabled": true,
  "enabledCookieJar": true,
  "enabledExplore": false,
  "loginUrl": "https://www.ciweimao.com/signup/login?redirect=https://www.ciweimao.com",
  "header": "<js>\nvar cookie = java.getCookie('https://www.ciweimao.com');\nJSON.stringify({\n  'User-Agent': 'Mozilla/5.0 (Linux; Android 11) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/91.0.4472.120 Mobile Safari/537.36',\n  'Cookie': cookie || ''\n});\n</js>",
  "respondTime": 180000,
  "searchUrl": "/get-search-book-list/0-0-0-0-0-0/全部/{{key}}/{{page}}",
  "ruleSearch": {
    "bookList": ".rank-book-list li||.book-list-table tr!0",
    "name": ".tit a@text||.col-title a@text",
    "author": ".author a@text||.col-author@text",
    "bookUrl": ".tit a@href||.col-title a@href",
    "coverUrl": ".cover img@src",
    "intro": ".desc@text",
    "kind": ".col-category@text"
  },
  "ruleBookInfo": {
    "name": "h1@text",
    "author": ".author-info a@text",
    "coverUrl": ".book-img img@src",
    "intro": ".book-intro@text",
    "kind": ".book-tags a@text",
    "tocUrl": "a[href*='chapter-list']@href",
    "wordCount": ".book-meta@text##总字数[：:](\\d+)"
  },
  "ruleToc": {
    "chapterList": ".catalogue li a, .book-chapter li a",
    "chapterName": "text",
    "chapterUrl": "href##$##,{\"webView\":true}",
    "isVip": "@js:result.outerHtml().includes('icon-lock')"
  },
  "ruleContent": {
    "content": "#J_BookRead .chapter@textNodes"
  }
}]
