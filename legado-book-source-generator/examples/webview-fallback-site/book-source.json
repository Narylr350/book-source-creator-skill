[
  {
    "bookSourceUrl": "https://webview-example.com",
    "bookSourceName": "示例WebView回退站点",
    "searchUrl": "https://webview-example.com/search?q={{key}}",
    "ruleSearch": {
      "bookList": ".search-results .book-item",
      "name": ".book-title",
      "bookUrl": "a@href"
    },
    "ruleBookInfo": {
      "name": ".book-title",
      "author": ".book-author",
      "coverUrl": ".book-cover img@src",
      "intro": ".book-desc",
      "tocUrl": ".toc-link@href"
    },
    "ruleToc": {
      "chapterList": ".chapter-list a",
      "chapterName": "text",
      "chapterUrl": "@href"
    },
    "ruleContent": {
      "content": "<js>\njava.ajax(url).body()\n</js>\n\n##.chapter-content\n\n{\"webView\": true}"
    }
  }
]
